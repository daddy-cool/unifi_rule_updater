{
  "name": "unifi-rule-updater",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun src/server.ts",
    "dev": "NODE_ENV=development bun --hot src/server.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit -p .",
    "validate": "bun run lint:fix && bun run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bun": "latest",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.7",
    "@logtape/pretty": "^2.0.7"
  }
}